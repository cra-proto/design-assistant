{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "schematicCollections": [
      "angular-eslint"
    ]
  },
  "newProjectRoot": "projects",
  "projects": {
    "design-assistant": {
      "i18n": {
        "sourceLocale": "en-CA",
        "locales": {
          "fr": {
            "translation": "src/locale/messages.fr.json"
          }
        }
      },
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "src",
      "prefix": "aida",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/design-assistant",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js",
              "@angular/localize/init"
            ],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              {
                "glob": "pdf.worker.min.mjs",
                "input": "node_modules/pdfjs-dist/build",
                "output": "pdfjs"
              },
              {
                "glob": "html.js",
                "input": "node_modules/prettier/plugins",
                "output": "prettier"
              },
              {
                "glob": "standalone.js",
                "input": "node_modules/prettier",
                "output": "prettier"
              },
              {
                "glob": "prism-okaidia.min.css",
                "input": "node_modules/prismjs/themes",
                "output": "css"
              },
              {
                "glob": "prism.min.css",
                "input": "node_modules/prismjs/themes",
                "output": "css"
              }
            ],
            "styles": [
              "node_modules/primeflex/primeflex.css",
              "node_modules/primeicons/primeicons.css",
              "src/styles.css",
              "diff2html/bundles/css/diff2html.min.css"
            ],
            "scripts": [
              "node_modules/underscore/underscore-min.js"
            ]
          },
          "configurations": {
            "production": {
              "fileReplacements": [],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2.6MB",
                  "maximumError": "3MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "allowedCommonJsDependencies": [
                "prettier/parser-html",
                "prismjs",
                "diff",
                "diff2html/lib/ui/js/diff2html-ui-slim",
                "highlight.js",
                "hogan.js",
                "mammoth",
                "bluebird/js/release/promise",
                "jszip",
                "@xmldom",
                "dingbat-to-unicode",
                "xmlbuilder",
                "lop",
                "base64-js"
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ]
            },
            "sandbox": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.sandbox.ts"
                }
              ]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "design-assistant:build:production"
            },
            "development": {
              "buildTarget": "design-assistant:build:development"
            },
            "sandbox": {
              "buildTarget": "design-assistant:build:sandbox"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing",
              "@angular/localize/init"
            ],
            "tsConfig": "tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              },
              {
                "glob": "pdf.worker.min.mjs",
                "input": "node_modules/pdfjs-dist/build",
                "output": "pdfjs"
              }
            ],
            "styles": [
              "src/styles.css"
            ],
            "scripts": [
              "node_modules/underscore/underscore-min.js"
            ]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "src/**/*.ts",
              "src/**/*.html"
            ]
          }
        }
      }
    }
  }
}